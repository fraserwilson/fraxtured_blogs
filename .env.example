# Shared
ASPNETCORE_ENVIRONMENT=Development
NEXT_PUBLIC_API_BASE_PATH=/api
API_PROXY_TARGET=http://api:5000
INTERNAL_API_BASE_URL=http://api:5000/api

# PostgreSQL
POSTGRES_DB=fracturedblogs
POSTGRES_USER=fracturedblogs
POSTGRES_PASSWORD=fracturedblogs_dev_pw
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=blogs

# API
API_PORT=5000
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=fracturedblogs;Username=fracturedblogs;Password=fracturedblogs_dev_pw
Security__WriteApiKey=replace-with-a-long-random-write-key
Cors__AllowedOrigins=http://localhost:3000
Jwt__Issuer=fracturedblogs-api
Jwt__Audience=fracturedblogs-web
Jwt__Key=replace-with-a-long-random-dev-key
Minio__Endpoint=minio:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Minio__UseSsl=false
Minio__BucketName=blogs
Minio__PublicBaseUrl=http://localhost:9000
Redis__ConnectionString=redis:6379

# Web
WEB_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://fracturedblogs.co.za
NEXTAUTH_SECRET=replace-with-a-long-random-secret
INTERNAL_API_WRITE_KEY=replace-with-the-same-write-key-as-api
AZURE_AD_CLIENT_ID=replace-with-entra-app-client-id
AZURE_AD_CLIENT_SECRET=replace-with-entra-app-client-secret
AZURE_AD_TENANT_ID=replace-with-entra-tenant-id
ALLOWED_EMAILS=you@yourdomain.com
ALLOWED_EMAIL_DOMAINS=
